{
  "name": "electron-sqlite-login",
  "version": "1.0.8",
  "description": "用户管理系统",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "publish": "npm run build && electron-builder --publish always"
  },
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "electron-updater": "^6.6.2",
    "sql.js": "^1.10.3",
    "update-electron-app": "^3.1.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.2.1",
    "electron": "^27.3.11",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.example.useradmin",
    "productName": "用户管理系统",
    "publish": [
      {
        "provider": "github",
        "owner": "zll123456354",
        "repo": "electron-sqlite",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist/package"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/**/*"
    ],
    "files": [
      "electron/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!dist/package/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "用户管理系统",
      "perMachine": true,
      "uninstallDisplayName": "用户管理系统 ${version}"
    }
  }
}
